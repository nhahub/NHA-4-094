# Supabase Project Configuration
# Replace with your actual project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key is preferred for backend ingestion bypass of Row Level Security (RLS).
# Keep this key safe and NEVER expose it to client/frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket configuration (must be created as private in Supabase Storage)
SUPABASE_STORAGE_BUCKET=study-documents

# Maximum allowed file upload size in Megabytes
MAX_UPLOAD_SIZE_MB=10

SUPABASE_DB_PASSWORD=your_actual_supabase_db_password

# Google Gemini API Key — kept in case it is used by LLM providers
GEMINI_API_KEY=

# Embedding Provider Configuration
# Supported providers: cloudflare, local
EMBEDDING_PROVIDER=cloudflare
EMBEDDING_MODEL_NAME=@cf/baai/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32

# Cloudflare Workers AI credentials (obtain from your Cloudflare dashboard)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_BASE_URL=https://api.cloudflare.com/client/v4
