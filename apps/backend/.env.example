# Environment & Auth Configuration
APP_ENV=development
AUTH_MODE=supabase
MOCK_USER_ID=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Supabase Project Configuration
# Replace with your actual project URL (e.g. https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key is preferred for backend ingestion bypass of Row Level Security (RLS).
# Keep this key safe and NEVER expose it to client/frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket configuration (must be created as private in Supabase Storage)
SUPABASE_STORAGE_BUCKET=study-documents

# Maximum allowed file upload size in Megabytes
MAX_UPLOAD_SIZE_MB=10

SUPABASE_DB_PASSWORD=your_actual_supabase_db_password

# Google Gemini API Key — kept in case it is used by LLM providers
GEMINI_API_KEY=

# ──────────────────────────────────────────────────────────────────
# GROQ API Keys (LLM backbone — get free keys at console.groq.com/keys)
# ──────────────────────────────────────────────────────────────────
# OPTION A (temporary): Single key shared across all task groups
GROQ_API_KEY=

# OPTION B (production): Per-task keys for fine-grained rate-limit control
# GROQ_FAST_API_KEYS=gsk_key1,gsk_key2        # fast/chat tasks
# GROQ_REASONING_API_KEYS=gsk_key1,gsk_key2   # deep-reasoning tasks
# GROQ_SUMMARY_API_KEYS=gsk_key1,gsk_key2     # summarization tasks
# GROQ_VERIFIER_API_KEYS=gsk_key1,gsk_key2    # verification/grading tasks


# Embedding Provider Configuration
# Supported providers: cloudflare, local
EMBEDDING_PROVIDER=cloudflare
EMBEDDING_MODEL_NAME=@cf/baai/bge-m3
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=32

# Cloudflare Workers AI credentials (obtain from your Cloudflare dashboard)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_BASE_URL=https://api.cloudflare.com/client/v4

# ──────────────────────────────────────────────────────────────────
# New LLM routing configurations
# ──────────────────────────────────────────────────────────────────
GROQ_PRIMARY_MODEL=openai/gpt-oss-120b
GROQ_FIRST_FALLBACK_MODEL=qwen/qwen3-32b
GROQ_EMERGENCY_FALLBACK_MODEL=llama-3.3-70b-versatile
GROQ_LIGHTWEIGHT_FALLBACK_MODEL=openai/gpt-oss-20b

# Reasoning policy
GROQ_PLANNING_REASONING_EFFORT=low
GROQ_MEMORY_MAP_REASONING_EFFORT=low
GROQ_QUERY_REWRITE_REASONING_EFFORT=low
GROQ_CHAT_REASONING_EFFORT=medium
GROQ_EXECUTION_REASONING_EFFORT=medium
GROQ_QUIZ_REASONING_EFFORT=medium
GROQ_VERIFICATION_REASONING_EFFORT=medium
GROQ_COMPLEX_REASONING_EFFORT=high
GROQ_INCLUDE_REASONING=false

# Reranker configurations
RERANKER_ENABLED=true
RERANKER_PROVIDER_ORDER=jina,cohere,cloudflare,rule_based,hybrid
RERANKER_CANDIDATE_K=25
RERANKER_TOP_K=8
RERANKER_TIMEOUT_SECONDS=15
RERANKER_MAX_RETRIES=1
RERANKER_RULE_BASED_FALLBACK=true
RERANKER_PRESERVE_HYBRID_ORDER_ON_FAILURE=true

# Jina reranker credentials
JINA_API_KEY=
JINA_RERANKER_ENDPOINT=https://api.jina.ai/v1/rerank
JINA_RERANKER_MODEL=jina-reranker-v3

# Cohere reranker credentials
COHERE_API_KEY=
COHERE_RERANKER_ENDPOINT=https://api.cohere.com/v2/rerank
COHERE_RERANKER_MODEL=rerank-v4.0-pro

# Cloudflare reranker model
CLOUDFLARE_RERANKER_MODEL=@cf/baai/bge-reranker-base
